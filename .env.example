# AWS S3 (required when using S3 upload service)
# Must match your S3 bucket region (rockyrealestate-website is eu-north-1)
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=rockyrealestate-website

# Optional S3 upload size limits (bytes). Defaults: image 5MB, video 100MB, pdf 10MB, cv 10MB
# AWS_S3_MAX_IMAGE_SIZE=5242880
# AWS_S3_MAX_VIDEO_SIZE=104857600
# AWS_S3_MAX_PDF_SIZE=10485760
# AWS_S3_MAX_CV_SIZE=10485760

# Zapier Catch Hook (optional). If unset, contact creation still succeeds; webhook is skipped.
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXX/YYYYY/

# Public API base URL (optional). Used for cvUrl / cvDownloadUrl in career applications.
# Example: https://backend.rockyrealestate.com
PUBLIC_BASE_URL=

# Google Apps Script web app URL for career applications → Google Sheets (optional).
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbwcXSWP1o5YPqc6WY2ENjxcDI6JaWIxULcxYjXJ77qpadPWkKyShpYJ3iRd0haJk4RAQw/exec

# Google Apps Script web app URL for Jewel Tower leads → Google Sheets (optional).
# GOOGLE_SHEETS_JEWEL_TOWER_LEAD_URL=https://script.google.com/macros/s/XXXX/exec

# Google Apps Script web app URL for landing page leads → Google Sheets (optional).
# GOOGLE_SHEETS_LANDING_PAGE_LEAD_URL=https://script.google.com/macros/s/XXXX/exec

# Zapier Catch Hook for Jewel Tower leads (optional).
# JEWEL_TOWER_ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXX/YYYYY/
