# Zapier Catch Hook (optional). If unset, contact creation still succeeds; webhook is skipped.
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/XXXXX/YYYYY/

# Public API base URL (optional). Used for cvUrl / cvDownloadUrl in career applications.
# Example: https://backend.rockyrealestate.com
PUBLIC_BASE_URL=

# Google Apps Script web app URL for career applications → Google Sheets (optional).
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbwcXSWP1o5YPqc6WY2ENjxcDI6JaWIxULcxYjXJ77qpadPWkKyShpYJ3iRd0haJk4RAQw/exec

# Google Apps Script web app URL for Jewel Tower leads → Google Sheets (optional).
# GOOGLE_SHEETS_JEWEL_TOWER_LEAD_URL=https://script.google.com/macros/s/XXXX/exec
